{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run RideUpUI Web",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"web"
			],
			"options": {
				"cwd": "${workspaceFolder}/RideUpUI"
			},
			"isBackground": true
		},
		{
			"label": "Run RideUpUI Web Foreground",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"web"
			],
			"options": {
				"cwd": "${workspaceFolder}/RideUpUI"
			},
			"isBackground": false
		}
	]
}